# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# The service auto-loads `.env` on startup (local dev). On Cloud Run these are set
# as deploy-time environment variables instead, and `.env` is not used.

# --- Required ---------------------------------------------------------------

# Target GCS bucket name (must already exist).
GCS_BUCKET=your-bucket-name

# Path to a service-account key JSON.
# Required for LOCAL runs (its private key signs the download URL).
# Leave unset on Cloud Run — the built-in service account signs via IAM instead.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account-key.json

# --- Optional ---------------------------------------------------------------

# Object name prefix inside the bucket (e.g. scenarios/scenario-....docx).
GCS_PREFIX=scenarios/

# Signed-URL lifetime in seconds. Default + max is 604800 (7 days).
SIGNED_URL_EXPIRY_SECONDS=604800

# Port the server binds to. Cloud Run sets this automatically.
PORT=8080
